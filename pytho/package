#write a program to filter even number from a list using  filter and a lambda function#
# list of numbers
numbers = [10, 15, 20, 25, 30, 35 , 33 , 40 , 45]

#using filter () with lambda to get even numbers
even_numbers = list(filter(lambda x: x % 2 == 0, numbers))

#display the result
print("original list:",numbers)
print("even numbers:",even_numbers)